node_modules
out
release
dist

# Not committed: provider SDKs are optional peer deps (whose transitive versions
# make an npm-install-generated lockfile fail `npm ci`), and the AWS SDK family
# is pinned to exact lockstep versions in package.json, so `npm install`
# resolves deterministically without a committed lockfile.
package-lock.json

# Editor + OS noise
.DS_Store
.idea
.vscode/*
!.vscode/settings.json
*.swp

# Transient transpiled vite configs (Node emits these next to electron.vite.config.ts)
electron.vite.config.*.mjs

# Intermediate icon iconset (regenerated by iconutil from icon.svg / icon.png)
build/icon.iconset
build/icon.png

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
